{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "model": "claude-sonnet-4-6",
  "defaultMode": "plan",
  "autoMemoryEnabled": true,
  "disableAllHooks": false,
  "permissions": {
    "allow": [],
    "deny": [
      "Bash(rm -rf *)",
      "Bash(git reset --hard *)",
      "Bash(git checkout -- *)",
      "Bash(killall *)",
      "Bash(pkill *)",
      "Bash(truncate *)"
    ]
  },
  "env": {
    "AGENT_GOVERNANCE_STANDARD": "1"
  }
}
